# Spoolman API target. If running in Docker on the same compose network,
# use the service name instead of localhost.
SPOOLMAN_URL=http://localhost:7912

# Web importer settings
IMPORTER_BASE_PATH=/importer
# Optional canonical browser URL for redirects/actions if served behind another host.
IMPORTER_PUBLIC_BASE_URL=
IMPORTER_DATA_DIR=/data
IMPORTER_WEBHOOK_TOKEN=change-me-long-random-token

# Paperless-ngx API access for webhook-triggered imports
PAPERLESS_URL=http://localhost:8000
PAPERLESS_TOKEN=change-me-paperless-api-token
PAPERLESS_IMPORT_TAG=filament

# Optional: only used if you later enable LLM fallback paths.
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Alternative examples
# SPOOLMAN_URL=https://spoolman.aspiderweb.uk
# PAPERLESS_URL=https://paperless.aspiderweb.uk
